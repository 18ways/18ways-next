{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "../../.cache/tsc/18ways-next.tsbuildinfo",
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "declaration": true,
    "outDir": "dist",
    "target": "es2015"
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "dist-types",
    "tests",
    "e2e",
    "examples",
    "**/*.test.ts",
    "**/*.test.tsx",
    "bun-build.ts",
    "vitest.config.ts",
    "vitest-setup.ts"
  ]
}

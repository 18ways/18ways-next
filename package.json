{
  "name": "@18ways/next",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/next.js",
  "module": "./dist/next.js",
  "types": "./dist-types/next.d.ts",
  "exports": {
    "./client": {
      "types": "./dist-types/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./config": {
      "types": "./dist-types/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js",
      "require": "./config.cjs"
    },
    "./internal-config": {
      "types": "./dist-types/internal-config.d.ts",
      "import": "./dist/internal-config.js",
      "default": "./dist/internal-config.js"
    },
    "./next-client": {
      "types": "./dist-types/next-client.d.ts",
      "import": "./dist/next-client.js",
      "default": "./dist/next-client.js"
    },
    "./proxy": {
      "types": "./dist-types/proxy.d.ts",
      "import": "./dist/proxy.js",
      "default": "./dist/proxy.js"
    },
    "./server": {
      "types": "./dist-types/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./rsc": {
      "types": "./dist-types/rsc.d.ts",
      "import": "./dist/rsc.js",
      "default": "./dist/rsc.js"
    }
  },
  "files": [
    "*.cjs",
    "dist",
    "dist-types",
    "global.d.ts"
  ],
  "scripts": {
    "build": "bun run bun-build.ts",
    "ts:check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "e2e": "cd e2e && mkdir -p test-results && bun scripts/run-e2e.ts --suite core"
  },
  "dependencies": {
    "@18ways/core": "*",
    "@18ways/react": "*",
    "jiti": "^1.21.7"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.1",
    "jsdom": "^26.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/18ways/18ways-next.git"
  },
  "homepage": "https://18ways.com/docs",
  "bugs": {
    "url": "https://github.com/18ways/18ways-next/issues"
  },
  "license": "MIT",
  "description": "Next.js adapter for 18ways",
  "packageManager": "bun@1.3.8"
}
